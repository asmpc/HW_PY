(
id INTEGER PRIMARY KEY AUTOINCREMENT,
age INTEGER CHECK(0&lt;age&lt;100),
sex TEXT CHECK(&quot;sex&quot; = &quot;male&quot; or &quot;sex&quot; = &quot;female&quot;),
country TEXT,
name TEXT NOT NULL,
last_name TEXT NOT NULL
)

ALTER TABLE actors
ADD salary INTEGER

ALTER TABLE actors
DROP COLUMN salary

