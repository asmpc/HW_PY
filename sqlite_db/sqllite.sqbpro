(&quot;Takeshi&quot;, &quot;Kitano&quot;)

UPDATE actors
SET country = &quot;Unknown&quot;
WHERE country IS NULL

UPDATE actors
SET age = age + 2
WHERE sex = &quot;female&quot; and age&gt;40

SELECT *
FROM actors
WHERE sex = &quot;female&quot; and age&lt;38

SELECT name, last_name, age
FROM actors
WHERE age &gt; 0
ORDER BY age
LIMIT 5

SELECT count(name), avg(age), min(age), max(age)
FROM actors

SELECT country,  5 &lt; count(country) &lt; 10
FROM actors

SELECT avg(age)
FROM actors
WHERE sex = &quot;male&quot;

SELECT avg(age)
FROM actors
WHERE sex = &quot;female&quot;

SELECT *
FROM actors
GROUP by country
HAVING min(age)

SELECT country
FROM actors
GROUP by country
HAVING count(DISTINCT sex) = 1 and sex = &quot;female&quot;

SELECT *
FROM actors
GROUP by country
HAVING max(age)

SELECT *
FROM actors
GROUP by country
HAVING avg(age)
ORDER BY avg(age) DESC
LIMIT 1

SELECT *
FROM actors
WHERE country IN 
(SELECT country 
FROM actors 
WHERE sex = &quot;female&quot; and age &gt;50)
ORDER BY country

SELECT country, sum(sex = &quot;male&quot;)*100 / count(sex)
FROM actors
GROUP BY country
ORDER BY sum(sex = &quot;male&quot;)*100 / count(sex) DESC

SELECT *
FROM actors
WHERE age IN 
(SELECT age 
FROM actors 
GROUP BY age 
HAVING count(*)&gt;2)
ORDER BY age DESC


